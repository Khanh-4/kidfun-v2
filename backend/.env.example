# Environment
NODE_ENV=development

# Backend Server
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001

# Database (SQLite for development)
DATABASE_URL="file:./dev.db"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URLs
PARENT_DASHBOARD_URL=http://localhost:3000
CHILD_MONITOR_URL=http://localhost:3002

# Socket.IO
# Khi chạy trên LAN, thêm IP của các thiết bị frontend vào danh sách
# Ví dụ: SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://192.168.1.101:3000,http://192.168.1.102:3002
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# SMTP (Gmail App Password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
